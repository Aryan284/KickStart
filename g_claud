#cut the edges in such a way that all the leaf nodes get disconnected from root 

class TreeNode:
      """Binary tree node with weighted edges to children."""

      def __init__(self, val):
          self.val = val
          self.left = None
          self.right = None
          # Edge weights from this node to each child.
          self.left_weight = 0
          self.right_weight = 0


def min_cost_to_disconnect_leaves(root):
      """
      Returns the minimum total edge-cost to ensure no leaf has a path
      to the root.

      Recurrence:
        For each child:
          option A: cut the edge between this node and child (cost = weight)
          option B: cut deeper inside child's subtree (cost = min_cost(child))
          Pick the smaller.

        Sum over all children.

        Leaves return infinity to force the parent to cut the edge above.

      Time: O(N), Space: O(H) recursion depth.
      """
      if root is None:
          return 0

      def dfs(node):
          # If this node has no children -> it's a leaf -> caller must cut
          # the edge to it. Return infinity so parent's min(edge, leaf) = edge.
          if node.left is None and node.right is None:
              return math.inf

          total = 0

          if node.left is not None:
              child_cost = dfs(node.left)
              total += min(node.left_weight, child_cost)

          if node.right is not None:
              child_cost = dfs(node.right)
              total += min(node.right_weight, child_cost)

          return total
  
      result = dfs(root)
      # If the root itself is a leaf, there's nothing to disconnect.
      return 0 if result == math.inf else result


  # ---------------------------------------------------------------------
  # Iterative version (for huge skewed trees)
  # ---------------------------------------------------------------------

def min_cost_iterative(root):
      """
      Same algorithm, iterative DFS with explicit stack.
      Safe for huge skewed trees that would blow recursion limits.
      """
      if root is None:
          return 0

      # Post-order traversal: process children before parent.
      # We use the standard "two-stack" or "visited flag" pattern.
      cost = {}                       # node id -> min_cost
      stack = [(root, False)]

      while stack:
          node, processed = stack.pop()
          if processed:
              # Compute this node's cost using its children's costs.
              if node.left is None and node.right is None:
                  cost[id(node)] = math.inf
                  continue

              total = 0
              if node.left is not None:
                  total += min(node.left_weight, cost[id(node.left)])
              if node.right is not None:
                  total += min(node.right_weight, cost[id(node.right)])
              cost[id(node)] = total
          else:
              # Re-push self with processed flag, then push children.
              stack.append((node, True))
              if node.right is not None:
                  stack.append((node.right, False))
              if node.left is not None:
                  stack.append((node.left, False))

      result = cost[id(root)]
      return 0 if result == math.inf else result


  # ---------------------------------------------------------------------
  # Demo
  # ---------------------------------------------------------------------

def demo():
      # Example from problem:
      #     6
      #    / \
      #  5/   \2
      #  4     2 (leaf)
      #  |
      # 1|
      #  1 (leaf)

      root = TreeNode(6)
      root.left = TreeNode(4)
      root.right = TreeNode(2)
      root.left_weight = 5
      root.right_weight = 2

      root.left.left = TreeNode(1)
      root.left.left_weight = 1

      print(f"Recursive: {min_cost_to_disconnect_leaves(root)}")  # 3
      print(f"Iterative: {min_cost_iterative(root)}")              # 3

      # Edge case: single leaf root
      leaf = TreeNode(1)
      print(f"Single leaf: {min_cost_to_disconnect_leaves(leaf)}")  # 0

      # Edge case: cheap deep cut
      #     A
