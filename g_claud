class CycleError(Exception):
      """Raised when the replacement graph contains a cycle."""


def substitute(replacements, text):
      """
      Replace every %key% in text with mapping[key], recursively expanding
      nested references in values. Raises CycleError if the replacement
      graph contains a cycle.

      Time:  O(total input size + total resolved size)
      Space: O(K + total resolved size)
      """
      # Build a plain dict from the input form (list of pairs or dict).
      mapping = dict(replacements) if isinstance(replacements, list) else replacements

      # Memoize fully-resolved values for each key.
      resolved = {}
      in_progress = set()

      def resolve_key(key):
          if key in resolved:
              return resolved[key]
          if key in in_progress:
              raise CycleError(f"Cycle detected involving key '{key}'")
          if key not in mapping:
              raise KeyError(f"Unknown placeholder '%{key}%'")

          in_progress.add(key)
          try:
              result = expand(mapping[key])
          finally:
              in_progress.discard(key)

          resolved[key] = result
          return result
  
      def expand(template):
          """
          Walk template character-by-character, replacing every %key%
          with its fully-resolved value (recursive call to resolve_key).
          Returns a new string with no remaining placeholders.
          """
          out = []
          i = 0
          n = len(template)
          while i < n:
              if template[i] == '%':
                  # Find the matching closing %.
                  end = template.find('%', i + 1)
                  if end == -1:
                      # Unmatched % -- treat as literal.
                      out.append(template[i])
                      i += 1
                      continue
                  key = template[i + 1:end]
                  if key == '':
                      # Empty %% -- treat as literal % (or whatever convention).
                      out.append('%')
                      i += 1
                      continue
                  # Recursively resolve and append.
                  out.append(resolve_key(key))
                  i = end + 1
              else:
                  out.append(template[i])
                  i += 1
          return ''.join(out)

      return expand(text)


  # ---------------------------------------------------------------------
  # Demo
  # ---------------------------------------------------------------------

def demo():
      # Example 1
      replacements = [["A", "abc"], ["B", "def"]]
      text = "%A%_%B%"
      print(f"Example 1: {substitute(replacements, text)}")
      # Expected: abc_def

      # Example 2 (with nested reference)
      replacements = {"USER": "admin", "HOME": "/%USER%/home"}
      text = "I am %USER% My home is %HOME%"
      print(f"Example 2: {substitute(replacements, text)}")
      # Expected: I am admin My home is /admin/home

      # Deep nesting
      replacements = {
          "A": "1%B%",
          "B": "2%C%",
          "C": "3%D%",
          "D": "4",
      }
      print(f"Deep nesting: {substitute(replacements, '%A%')}")
      # Expected: 1234

      # Repeated reference (memoization saves work)
      replacements = {
          "X": "%Y%-%Y%",
          "Y": "%Z%",
          "Z": "hello",
      }
      print(f"Repeated reference: {substitute(replacements, '%X%')}")
      # Expected: hello-hello

      # Cycle detection
      replacements = {"A": "%B%", "B": "%A%"}
      try:
          substitute(replacements, "%A%")
      except CycleError as e:
          print(f"Cycle detected: {e}")

      # Unknown placeholder
      replacements = {"A": "abc"}
      try:
          substitute(replacements, "%Z%")
      except KeyError as e:
          print(f"Unknown placeholder: {e}")

      # No placeholders -- text returned unchanged
      print(f"No placeholders: {substitute({}, 'hello world')}")
      # Expected: hello world


if __name__ == "__main__":
      demo()


