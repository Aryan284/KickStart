  def max_customers_optimal(initial, arr):
      """
      Sliding window approach. We want the longest contiguous window [L, R]
      such that initial + every prefix sum starting at L stays >= 0.

      Equivalently: min(prefix[L+1..R+1]) >= prefix[L] - initial,
      where prefix[i] = sum(arr[0..i-1]).

      Use a monotonic deque to track min prefix sum in O(1) per query.

      Time: O(N), Space: O(N).
      """
      n = len(arr)
      if n == 0:
          return 0

      # Compute prefix sums. prefix[i] = sum(arr[0..i-1]).
      prefix = [0] * (n + 1)
      for i in range(n):
          prefix[i + 1] = prefix[i] + arr[i]

      # Sliding window over [L..R] (inclusive in arr-indices).
      # Monotonic deque holds indices into prefix array, sorted by value.
      # Front = index of minimum prefix value in current window.
      L = 0
      max_count = 0
      min_deque = deque()  # indices into prefix, values increasing

      for R in range(n):
          # Add prefix[R+1] to the deque, maintaining increasing order.
          while min_deque and prefix[min_deque[-1]] >= prefix[R + 1]:
              min_deque.pop()
          min_deque.append(R + 1)

          # Shrink from left while constraint violated.
          # Constraint: min(prefix[L+1..R+1]) >= prefix[L] - initial
          while min_deque and prefix[min_deque[0]] < prefix[L] - initial:
              L += 1
              # Remove deque entries that are now outside the window.
              while min_deque and min_deque[0] < L + 1:
                  min_deque.popleft()
              if L > R:
                  break

          if L <= R:
              count = R - L + 1
              if count > max_count:
                  max_count = count

      return max_count


  # ---------------------------------------------------------------------
  # Demo
  # ---------------------------------------------------------------------

