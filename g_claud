# return the mean value of the last N elements, excluding the largest K elements.

from collections import deque
from sortedcontainers import SortedList


class StreamingMeanExcludingTopK:
      """
      Maintains a sliding window of the last N elements, computing
      the mean excluding the largest K on every insert.
      """

      def __init__(self, n, k):
          if k >= n:
              raise ValueError("k must be < n")
          self._n = n
          self._k = k
          self._window = deque()        # FIFO of last N elements
          self._sorted = SortedList()   # the same elements in sorted order

      def add(self, value):
          """Insert a new element; return the current mean excluding top-K."""
          # Evict the oldest if window is full.
          if len(self._window) == self._n:
              old = self._window.popleft()
              self._sorted.remove(old)

          self._window.append(value)
          self._sorted.add(value)

          return self._mean_excluding_top_k()

      def _mean_excluding_top_k(self):
          """Mean of bottom (size - k) elements. Returns 0 if size <= k."""
          size = len(self._sorted)
          denom = size - self._k
          if denom <= 0:
              return 0.0  # or None; per problem spec
          # Sum the smallest (size - k) elements.
          bottom_sum = sum(self._sorted[:denom])
          return bottom_sum / denom


  # ---------------------------------------------------------------------
  # Demo
  # ---------------------------------------------------------------------

def demo_v1():
      stream = [20, 2, -2, 0, 10, 1, 5, -2, 0]
      sm = StreamingMeanExcludingTopK(n=5, k=2)

      print("Stream | Window | Result")
      for v in stream:
          result = sm.add(v)
          print(f"  {v:3} | {list(sm._window)} | {result:.4f}")

      # Final result for last 5 = [10, 1, 5, -2, 0]
      # Drop top 2: [10, 5]
      # Mean of [1, -2, 0] = -0.3333


if __name__ == "__main__":
