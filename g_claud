          ("id3", ["p5", "p7", "p8"]),
      ]
      print("\nExample 2 (transitive):")
      print(f"  Result: {find_duplicate_groups(elements_2)}")
      # Expected: [['id1', 'id2', 'id3']]

      # Edge case: all elements isolated
      elements_3 = [
          ("id1", ["a", "b", "c"]),
          ("id2", ["d", "e", "f"]),
          ("id3", ["g", "h", "i"]),
      ]
      print("\nEdge case (all isolated):")
