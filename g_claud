# Normal nodes : with two children
# Leaf nodes : no children
# Special nodes : only one children.
# Multiple consecutive Special nodes make a Special nodes Chain. like (a → b → c) are the node chain, so length is 3 here.
# Followup: return all the unique chain lengths and its count in the tree.
#TC: SC:# O(N)
from collections import defaultdict
  

class TreeNode:
    def __init__(self, val=0, left=None, right=None):
          self.val = val
          self.left = left
          self.right = right


def analyze_special_chains(root):
      """
      Return a dict: chain_length -> number of chains of that length.

      Single DFS pass. O(N) time, O(H) recursion depth where H = tree height.
      For balanced trees H = log N; for skewed H = N. Switch to iterative
      DFS for huge skewed trees to avoid stack overflow.
      """
      chain_counts = defaultdict(int)

def dfs(node, current_chain):
    if node is None:
        return
  
    child_count = (node.left is not None) + (node.right is not None)
    
    if child_count == 1:
    # Special node - extend the chain.
        child = node.left if node.left is not None else node.right
        dfs(child, current_chain + 1)
    else:
    # Chain ends here (either at a leaf or a normal node).
        if current_chain > 0:
            chain_counts[current_chain] += 1
    # If normal node, recurse into both children, each starting fresh.
    if child_count == 2:
      dfs(node.left, 0)
      dfs(node.right, 0)
    
    dfs(root, 0)
    return dict(chain_counts)


def max_chain_length(root):
      """Convenience wrapper: just the max chain length."""
      counts = analyze_special_chains(root)
      return max(counts.keys()) if counts else 0


  # ---------------------------------------------------------------------
  # Iterative version for huge skewed trees (Part 2 follow-up)
  # ---------------------------------------------------------------------

def analyze_special_chains_iterative(root):
      """
      Same as above but iterative -- O(1) extra recursion depth.
      Uses an explicit stack of (node, current_chain) pairs.

      Critical for huge skewed trees where recursion would blow the stack.
      """
      if root is None:
          return {}

      chain_counts = defaultdict(int)
      stack = [(root, 0)]  # (node, current_chain)

      while stack:
          node, current_chain = stack.pop()
  
          child_count = (node.left is not None) + (node.right is not None)

          if child_count == 1:
              child = node.left if node.left is not None else node.right
              stack.append((child, current_chain + 1))
          else:
              if current_chain > 0:
                  chain_counts[current_chain] += 1
              if child_count == 2:
                  stack.append((node.left, 0))
                  stack.append((node.right, 0))

      return dict(chain_counts)
  

  # ---------------------------------------------------------------------
  # Demo
  # ---------------------------------------------------------------------

