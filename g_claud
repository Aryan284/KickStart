  """
  Group elements where two are 'duplicates' if they share any property.
  Transitive: if E1 ~ E2 and E2 ~ E3, then E1 ~ E3.

  Standard library only.
  """
  
  from collections import defaultdict


  class DSU:
      """Disjoint Set Union with path compression and union by rank."""

      def __init__(self):
          self._parent = {}
          self._rank = {}

      def make_set(self, x):
          if x not in self._parent:
              self._parent[x] = x
              self._rank[x] = 0

      def find(self, x):
          # Iterative path compression -- safe for huge inputs.
          self.make_set(x)
          root = x
          while self._parent[root] != root:
              root = self._parent[root]
          # Compress path.
          current = x
          while self._parent[current] != root:
              nxt = self._parent[current]
              self._parent[current] = root
              current = nxt
          return root

      def union(self, x, y):
          rx, ry = self.find(x), self.find(y)
          if rx == ry:
              return
          # Union by rank: shorter tree under taller.
          if self._rank[rx] < self._rank[ry]:
              self._parent[rx] = ry
          elif self._rank[rx] > self._rank[ry]:
              self._parent[ry] = rx
          else:
              self._parent[ry] = rx
              self._rank[rx] += 1


  def find_duplicate_groups(elements):
      """
      Group element IDs by transitive property-sharing.

      Args:
          elements: list of (id, [props]) tuples

      Returns:
          list of lists -- each inner list is one group of element IDs,
          in input order.

      Time: O(N * K * alpha(N)) where K = avg properties per element.
      Space: O(N + total_properties)
      """
      dsu = DSU()
      prop_owner = {}                # property -> first element seen with it
      insertion_order = []           # preserve element order

      for elem_id, props in elements:
          dsu.make_set(elem_id)
          insertion_order.append(elem_id)
          for p in props:
              if p in prop_owner:
                  # This property was claimed -- union with its owner.
                  dsu.union(elem_id, prop_owner[p])
              else:
                  # First time seeing this property -- claim it.
                  prop_owner[p] = elem_id

      # Group element IDs by their DSU root, preserving insertion order.
      root_to_group = defaultdict(list)
      for elem_id in insertion_order:
          root = dsu.find(elem_id)
          root_to_group[root].append(elem_id)

      # Return groups in the order their first element was inserted.
      seen_roots = set()
      result = []
      for elem_id in insertion_order:
          root = dsu.find(elem_id)
          if root not in seen_roots:
              seen_roots.add(root)
              result.append(root_to_group[root])
      return result
  

  # ---------------------------------------------------------------------
  # Demo
  # ---------------------------------------------------------------------

  def demo():
      # Example 1: E1 and E2 share p1; E3 shares nothing -> {{id1, id2}, {id3}}
      elements_1 = [
          ("id1", ["p1", "p2", "p3"]),
          ("id2", ["p1", "p4", "p5"]),
          ("id3", ["p6", "p7", "p8"]),
      ]
      print("Example 1:")
      print(f"  Result: {find_duplicate_groups(elements_1)}")
      # Expected: [['id1', 'id2'], ['id3']]

      # Example 2: E1-E2 share p1; E2-E3 share p5; transitive -> {{id1, id2, id3}}
      elements_2 = [
          ("id1", ["p1", "p2", "p3"]),
