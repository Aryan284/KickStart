  """
  Food Delivery Payment System - LLD Solution (minimal libraries)
  ================================================================
  Only uses: datetime, Decimal, heapq (all standard library, no extras).
  No dataclass, no itertools.
  """

  from datetime import datetime, timedelta, timezone
  from decimal import Decimal
  from heapq import heappush, heappop


  # ---------------------------------------------------------------------------
  # Domain models (plain classes)
  # ---------------------------------------------------------------------------

  class Driver:
      """Represents a delivery driver with a fixed hourly rate."""

      def __init__(self, driver_id, hourly_rate):
          self.id = driver_id
          self.hourly_rate = hourly_rate

      def __repr__(self):
          return f"Driver(id={self.id}, rate={self.hourly_rate})"


  class Delivery:
      """
      Represents one completed delivery.
      Cost is precomputed at construction time so reads stay O(1)
      and the rate is locked in at delivery time (correct payroll behavior).
      """

      def __init__(self, driver_id, start_time, end_time, cost):
          self.driver_id = driver_id
          self.start_time = start_time
          self.end_time = end_time
          self.cost = cost

      def __repr__(self):
          return (f"Delivery(driver={self.driver_id}, "
                  f"start={self.start_time}, end={self.end_time}, "
                  f"cost={self.cost})")


  # ---------------------------------------------------------------------------
  # Main system
  # ---------------------------------------------------------------------------

  class DeliverySystem:
      """
      Design choices:
        - Decimal for money (float drift would compound across millions of rows).
        - datetime in UTC for timezone safety; only durations matter.
        - Running totals updated on write -> dashboard reads are O(1).
        - Min-heap of unpaid deliveries keyed by end_time -> payUpTo is fast
          (each delivery is paid exactly once, so it's amortized cheap).
      """

      def __init__(self):
          # driver_id -> Driver
          self._drivers = {}

          # Lifetime aggregate cost across all recorded deliveries.
          # Maintained incrementally so getTotalCost() is O(1).
          self._total_cost = Decimal("0")

          # Aggregate cost of deliveries not yet paid.
          # Maintained incrementally so getTotalCostUnpaid() is O(1).
          self._total_unpaid = Decimal("0")

          # Min-heap of unpaid deliveries ordered by end_time.
          # Tuple shape: (end_time, tie_breaker, Delivery)
          # The tie_breaker (monotonic int) prevents heapq from comparing
          # Delivery objects when two end_times are exactly equal --
          # without it, Python would try Delivery < Delivery and crash.
          self._unpaid = []
          self._tie_breaker = 0  # increments on every insert -- always unique

          # Keep all deliveries for analytics (Q3 follow-up).
          # In production this would live in a database, not memory.
          self._all_deliveries = []

      # -----------------------------------------------------------------------
      # Q1: addDriver, recordDelivery, getTotalCost
      # -----------------------------------------------------------------------

      def add_driver(self, driver_id, usd_hourly_rate):
          """
          Register a new driver. Per problem statement, the driver is not
          already in the system, so no duplicate check is required.

          Note on Decimal(str(float)):
            Decimal(0.1) -> 0.1000000000000000055511151231257827021181583404541015625
            Decimal("0.1") -> 0.1
            Going via str avoids inheriting the float's binary noise.
          """
          rate = Decimal(str(usd_hourly_rate))
          self._drivers[driver_id] = Driver(driver_id, rate)

      def record_delivery(self, driver_id, start_time, end_time):
          """
          Record a completed delivery. Per problem statement:
            - driver already exists
            - inputs are valid (end_time > start_time, duration <= 3h)
            - called immediately after delivery completes
          """
          driver = self._drivers[driver_id]

          # Duration in fractional hours, computed precisely.
          duration_seconds = (end_time - start_time).total_seconds()
          hours = Decimal(str(duration_seconds)) / Decimal("3600")
          cost = driver.hourly_rate * hours

          delivery = Delivery(driver_id, start_time, end_time, cost)

          # Update running aggregates and unpaid queue.
          self._total_cost += cost
          self._total_unpaid += cost

          # Push onto heap with a unique tie-breaker so heapq never tries
          # to compare two Delivery objects directly.
          heappush(self._unpaid, (end_time, self._tie_breaker, delivery))
          self._tie_breaker += 1

          self._all_deliveries.append(delivery)

      def get_total_cost(self):
          """O(1) -- dashboard friendly."""
          return self._total_cost

      # -----------------------------------------------------------------------
      # Q2: payUpTo, getTotalCostUnpaid
      # -----------------------------------------------------------------------

      def pay_up_to(self, pay_time):
          """
          Mark every unpaid delivery whose end_time <= pay_time as paid.

          Each delivery is paid exactly once across the system's lifetime,
          so the total work is O(n log n) amortized -- not per call.
          """
          # Peek the smallest end_time; pop while it's within the pay window.
          while self._unpaid and self._unpaid[0][0] <= pay_time:
              _, _, delivery = heappop(self._unpaid)
              self._total_unpaid -= delivery.cost

      def get_total_cost_unpaid(self):
          """O(1) -- dashboard friendly."""
          return self._total_unpaid

      # -----------------------------------------------------------------------
      # Q3 (follow-up): max simultaneous deliveries across all drivers
      # -----------------------------------------------------------------------

      def max_simultaneous_deliveries(self):
          """
          Sweep-line algorithm:
            - Each delivery becomes two events: (start, +1) and (end, -1).
            - Sort events by time; on ties, process ENDs before STARTs so a
              delivery ending at T and another starting at T are not counted
              as simultaneous (they're back-to-back, not overlapping).
            - Sweep through, tracking the running count of active deliveries.

          Complexity: O(n log n) sort, O(n) sweep.
          """
          events = []
          for d in self._all_deliveries:
              events.append((d.start_time, 1))   # +1 when a delivery starts
              events.append((d.end_time, -1))    # -1 when a delivery ends

          # Sort by time. Tie-break: -1 (end) before +1 (start) at same instant.
          # Sorting on (time, delta) puts -1 first because -1 < +1.
          events.sort(key=lambda e: (e[0], e[1]))

          active = 0
          peak = 0
          for _, delta in events:
              active += delta
              if active > peak:
                  peak = active
          return peak

      def overlap_intervals(self):
          """
          Bonus variant: return the actual time ranges during which 2+
          deliveries are happening simultaneously across the system.
          """
          events = []
          for d in self._all_deliveries:
              events.append((d.start_time, 1))
              events.append((d.end_time, -1))
          events.sort(key=lambda e: (e[0], e[1]))

          intervals = []
          active = 0
          overlap_start = None
          for time, delta in events:
              prev = active
              active += delta
              # Transition into overlap (1 -> 2)
              if prev < 2 and active >= 2:
                  overlap_start = time
              # Transition out of overlap (2 -> 1)
              elif prev >= 2 and active < 2 and overlap_start is not None:
                  intervals.append((overlap_start, time))
                  overlap_start = None
          return intervals


  # ---------------------------------------------------------------------------
  # Demo / sanity tests
  # ---------------------------------------------------------------------------

  def demo():
      system = DeliverySystem()

      # Two drivers with different rates.
      system.add_driver(driver_id=1, usd_hourly_rate=10.00)
      system.add_driver(driver_id=2, usd_hourly_rate=20.00)

      base = datetime(2026, 5, 30, 9, 0, tzinfo=timezone.utc)

      # Driver 1: 1.5h delivery -> $15.00
      system.record_delivery(1, base, base + timedelta(hours=1, minutes=30))

      # Driver 1: 2h delivery, overlaps the first -> $20.00
      system.record_delivery(1,
                             base + timedelta(minutes=30),
                             base + timedelta(hours=2, minutes=30))

      # Driver 2: 1h delivery, also overlapping -> $20.00
      system.record_delivery(2,
                             base + timedelta(hours=1),
                             base + timedelta(hours=2))

      # ---- Q1 ----
      print("Total cost:", system.get_total_cost())          # 55.00
      print("Total unpaid:", system.get_total_cost_unpaid()) # 55.00

      # ---- Q2 ----
      # Pay everything ending at or before base + 2h.
      # Covers delivery 1 (ends at +1.5h) and delivery 3 (ends at +2h).
      # Delivery 2 (ends at +2.5h) remains unpaid.
      system.pay_up_to(base + timedelta(hours=2))
      print("After payUpTo(+2h):")
      print("  Total cost (lifetime):", system.get_total_cost())      # 55.00
      print("  Total unpaid:", system.get_total_cost_unpaid())        # 20.00

      # ---- Q3 follow-up ----
      print("Peak simultaneous deliveries:",
            system.max_simultaneous_deliveries())  # 3 between [+1h, +1.5h]
      print("Overlap intervals (>=2 active):")
      for start, end in system.overlap_intervals():
          print(f"  {start.time()} -> {end.time()}")


  if __name__ == "__main__":
      demo()






  """
  Music Player with Star/Unstar + Last N Favourites
  ==================================================
  Adds:
    - star(song_id, user_id)
    - unstar(song_id, user_id)
    - get_last_n_favourite_songs(user_id, n)
  """

  from collections import OrderedDict

  
  class Song:
      """A song with a unique-listeners set for O(1) dedup."""

      def __init__(self, song_id, title):
          self.id = song_id
          self.title = title
          self.unique_listeners = set()

      def play_count(self):
          return len(self.unique_listeners)
  

  class UserProfile:
      """
      Per-user state. Extracted into its own class because the per-user
      surface area is growing (history + starred + future features).
      """

      def __init__(self):
          # Insertion-ordered, dedupe via move_to_end.
          # Most-recent at the END (consistent with OrderedDict semantics).
          self.play_history = OrderedDict()
          self.starred = set()

      def record_play(self, song_id, max_history):
          """Move-to-end on replay, else insert; cap total history."""
          if song_id in self.play_history:
              self.play_history.move_to_end(song_id)
          else:
              self.play_history[song_id] = None
              if len(self.play_history) > max_history:
                  # Evict oldest (FIFO).
                  self.play_history.popitem(last=False)

      def star(self, song_id):
          self.starred.add(song_id)

      def unstar(self, song_id):
          # discard, not remove -- silent no-op if not starred.
          self.starred.discard(song_id)


  class MusicPlayer:
      """
      Catalog + per-user state.

      Design notes on getLastNFavourite:
        - O(P) worst-case read where P = user's history size.
        - P is bounded by MAX_HISTORY, so effectively constant.
        - If profiling showed this as a hot path, I'd add a parallel
          starred_history OrderedDict updated on play/star/unstar.
      """

      HISTORY_LIMIT_FOR_LAST_THREE = 3
      MAX_HISTORY = 1000  # cap per-user history to bound memory

      def __init__(self):
          self._songs = {}
          self._next_id = 1
          self._users = {}  # user_id -> UserProfile

      # --------- internal ---------

      def _profile(self, user_id):
          if user_id not in self._users:
              self._users[user_id] = UserProfile()
          return self._users[user_id]

      # --------- core ---------

      def add_song(self, song_title):
          song_id = self._next_id
          self._next_id += 1
          self._songs[song_id] = Song(song_id, song_title)
          return song_id

      def play_song(self, song_id, user_id):
          song = self._songs[song_id]
          song.unique_listeners.add(user_id)
          self._profile(user_id).record_play(song_id, self.MAX_HISTORY)

      def print_most_played_songs(self):
          ranked = sorted(
              self._songs.values(),
              key=lambda s: (-s.play_count(), s.id),
          )
          for song in ranked:
              print(song.title)

      # --------- last 3 (original follow-up) ---------

      def get_last_three_songs(self, user_id):
          """Most-recent first, up to 3."""
          history = self._profile(user_id).play_history
          # Take last 3 keys, then reverse so most-recent is first.
          recent = list(history.keys())[-3:]
          return list(reversed(recent))

      # --------- new follow-up: star / unstar / last N favourites ---------

      def star(self, song_id, user_id):
          """Mark a song as favourite for this user. O(1)."""
          # Validate song exists; silently ignore unknown song_ids
          # (or raise -- depends on product spec).
          if song_id in self._songs:
              self._profile(user_id).star(song_id)

      def unstar(self, song_id, user_id):
          """Remove favourite mark. O(1). Silent no-op if not starred."""
          if user_id in self._users:
              self._users[user_id].unstar(song_id)

      def get_last_n_favourite_songs(self, user_id, n):
          """
          Last N unique starred songs the user has played, most-recent first.
          Semantics: 'starred NOW' (not at play time) -- if user unstars,
          the song no longer appears.

          Walk play history reverse, filter by starred, stop at N.
          Complexity: O(P) worst case where P = history size (capped).
          """
          if user_id not in self._users:
              return []
          profile = self._users[user_id]

          result = []
          # OrderedDict is iterable; reversed() walks newest -> oldest.
          for song_id in reversed(profile.play_history):
              if song_id in profile.starred:
                  result.append(song_id)
                  if len(result) == n:
                      break
          return result


  # ---------------------------------------------------------------------------
  # Demo
  # ---------------------------------------------------------------------------

  def demo():
      mp = MusicPlayer()
      s1 = mp.add_song("Bohemian Rhapsody")
      s2 = mp.add_song("Imagine")
      s3 = mp.add_song("Hotel California")
      s4 = mp.add_song("Stairway to Heaven")
      s5 = mp.add_song("Wonderwall")

      user = 100
  
      # User plays a sequence; stars some of them.
      mp.play_song(s1, user)
      mp.play_song(s2, user)
      mp.star(s2, user)             # Imagine starred
      mp.play_song(s3, user)
      mp.star(s3, user)             # Hotel California starred
      mp.play_song(s4, user)
      mp.play_song(s5, user)
      mp.star(s5, user)             # Wonderwall starred

      # Play history (oldest -> newest): s1, s2, s3, s4, s5
      # Starred: {s2, s3, s5}

      print("Last 3 songs:", mp.get_last_three_songs(user))
      # Expected: [s5, s4, s3] -- most recent regardless of stars

      print("Last 2 favourites:", mp.get_last_n_favourite_songs(user, 2))
      # Expected: [s5, s3] -- most recent starred ones

      print("Last 5 favourites:", mp.get_last_n_favourite_songs(user, 5))
      # Expected: [s5, s3, s2] -- only 3 starred exist

      # Unstar s3 -> shouldn't appear anymore
      mp.unstar(s3, user)
      print("After unstarring s3, last 5 favourites:",
            mp.get_last_n_favourite_songs(user, 5))
      # Expected: [s5, s2]

      # Replay s2 -> bumps to most recent in history
      mp.play_song(s2, user)
      print("After replaying s2, last 5 favourites:",
            mp.get_last_n_favourite_songs(user, 5))
      # Expected: [s2, s5]


  if __name__ == "__main__":
      demo()
  
