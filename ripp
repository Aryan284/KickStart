  """
  Excel Spreadsheet - LLD Solution (no regex)
  ============================================
  Standard library only: no imports needed.
  """


  # ---------------------------------------------------------------------------
  # Value types (Strategy pattern)
  # ---------------------------------------------------------------------------

  class CellValue:
      """Abstract base. Each value type knows how to evaluate itself."""

      def evaluate(self, spreadsheet, evaluating):
          raise NotImplementedError


  class LiteralValue(CellValue):
      """A plain integer."""

      def __init__(self, value):
          self.value = value

      def evaluate(self, spreadsheet, evaluating):
          return self.value


  class FormulaValue(CellValue):
      """
      A '+'-joined formula. Operands can be integers or cell references.
      Stored as list of (kind, value) tuples:
          kind == "int" -> value is int
          kind == "ref" -> value is cell_id string
      """

      def __init__(self, operands):
          self.operands = operands

      def evaluate(self, spreadsheet, evaluating):
          total = 0
          for kind, v in self.operands:
              if kind == "int":
                  total += v
              else:
                  total += spreadsheet._resolve(v, evaluating)
          return total


  # ---------------------------------------------------------------------------
  # Cell wrapper
  # ---------------------------------------------------------------------------

  class Cell:
      """Pairs the raw user string with the parsed CellValue."""

      def __init__(self, raw, value):
          self.raw = raw
          self.value = value


  # ---------------------------------------------------------------------------
  # Hand-rolled parsing
  # ---------------------------------------------------------------------------

  def _is_digit(ch):
      return '0' <= ch <= '9'


  def _is_letter(ch):
      return 'A' <= ch <= 'Z'
  

  def _is_signed_integer(token):
      """
      Check if token is a valid signed integer like '5', '-3', '-100'.
      Allows an optional leading '-', then one or more digits.
      """
      if not token:
          return False
      start = 1 if token[0] == '-' else 0
      if start == len(token):  # just a '-' with no digits
          return False
      for i in range(start, len(token)):
          if not _is_digit(token[i]):
              return False
      return True
  

  def _is_cell_ref(token):
      """
      Check if token is a valid cell reference like 'A1', 'B12', 'AA1'.
      One or more uppercase letters followed by one or more digits.
      """
      if not token:
          return False
      i = 0
      # Consume letters
      while i < len(token) and _is_letter(token[i]):
          i += 1
      if i == 0:
          return False  # no letters
      letter_end = i
      # Consume digits
      while i < len(token) and _is_digit(token[i]):
          i += 1
      # Must have at least one digit, and consumed everything
      return i > letter_end and i == len(token)


  def _parse_operand(token):
      """Classify a token as int or ref. Raises ValueError if neither."""
      if _is_signed_integer(token):
          return ("int", int(token))
      if _is_cell_ref(token):
          return ("ref", token)
      raise ValueError(f"Invalid operand: {token!r}")


  def _split_formula(body):
      """
      Split formula body on '+' separators.
      Crucial: '+' is the ONLY separator. '-' is always a sign, never a
      separator. So splitting on '+' is unambiguous:
          '-1+-10+2' -> ['-1', '-10', '2']
          '2+8'      -> ['2', '8']
          'A1+10'    -> ['A1', '10']
      """
      tokens = []
      current = []
      for ch in body:
          if ch == '+':
              tokens.append(''.join(current))
              current = []
          else:
              current.append(ch)
      tokens.append(''.join(current))
      return tokens


  def _parse_value(raw):
      """Parse a raw user string into a CellValue."""
      if raw.startswith('='):
          body = raw[1:]
          tokens = _split_formula(body)
          operands = [_parse_operand(t) for t in tokens]
          return FormulaValue(operands)
      # Plain integer literal
      if not _is_signed_integer(raw):
          raise ValueError(f"Invalid literal: {raw!r}")
      return LiteralValue(int(raw))


  # ---------------------------------------------------------------------------
  # Spreadsheet
  # ---------------------------------------------------------------------------

  class CycleError(Exception):
      """Internal exception for cycle detection."""


  class Spreadsheet:
      """
      Stores cells sparsely. Parses on `set`, evaluates lazily on `print`
      with memoization within a single print pass and DFS-based cycle detection.
      """

      def __init__(self):
          self._cells = {}  # cell_id -> Cell

      def set(self, cell_id, raw_value):
          """Set or update a cell. Empty string resets the cell."""
          if raw_value == "":
              self.reset(cell_id)
              return
          value = _parse_value(raw_value)
          self._cells[cell_id] = Cell(raw_value, value)

      def reset(self, cell_id):
          """Remove a cell entirely."""
          self._cells.pop(cell_id, None)

      def print(self):
          """Print every cell with raw and computed values."""
          cache = {}  # memoize within this print pass
          for cell_id in sorted(self._cells.keys()):
              cell = self._cells[cell_id]
              computed = self._evaluate_with_cache(cell_id, cache)
              print(f"{cell_id}: raw='{cell.raw}', computed={computed}")

      # ----- internal -----

      def _evaluate_with_cache(self, cell_id, cache):
          if cell_id in cache:
              return cache[cell_id]
          try:
              result = self._resolve(cell_id, evaluating=set())
          except CycleError:
              result = "ERROR(cycle)"
          cache[cell_id] = result
          return result

      def _resolve(self, cell_id, evaluating):
          """Resolve a cell's value with cycle detection."""
          if cell_id in evaluating:
              raise CycleError()
          if cell_id not in self._cells:
              # Reference to unset cell -> treat as 0 (Excel convention).
              return 0

          evaluating.add(cell_id)
          try:
              return self._cells[cell_id].value.evaluate(self, evaluating)
          finally:
              evaluating.discard(cell_id)


  # ---------------------------------------------------------------------------
  # Demo
  # ---------------------------------------------------------------------------

  def demo():
      sheet = Spreadsheet()

      # Basic literals and formulas
      sheet.set("A1", "10")
      sheet.set("A2", "-5")
      sheet.set("B1", "=2+8")
      sheet.set("B2", "=-1+-10+2")
      sheet.set("C1", "100")

      print("--- Initial sheet ---")
      sheet.print()

      print("\n--- After reset(C1) and set(A2, '') ---")
      sheet.reset("C1")
      sheet.set("A2", "")
      sheet.print()

      # Follow-up: references
      print("\n--- With references ---")
      sheet.set("D1", "=A1+10")        # 10 + 10 = 20
      sheet.set("D2", "=A1+B1")        # 10 + 10 = 20
      sheet.set("D3", "=D1+D2+5")      # 20 + 20 + 5 = 45
      sheet.print()

      # Cycle
      print("\n--- With a cycle (E1 -> E2 -> E1) ---")
      sheet.set("E1", "=E2+1")
      sheet.set("E2", "=E1+1")
      sheet.print()

      # Reference to unset cell
      print("\n--- Reference to unset cell ---")
      sheet.set("F1", "=Z9+5")
      sheet.print()


  if __name__ == "__main__":
      demo()
  
