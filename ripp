  Violation(rule=R2, expenses=['003'], trip=T1, desc='expense_type cannot be 'airfare'')
  Violation(rule=R4, expenses=['003'], trip=T1, desc='Single expense cannot exceed $250')
  Violation(rule=R6, expenses=['002', '004'], trip=T1, desc='Total expense_type=meal per trip cannot exceed $200')

  5. Time & Space Complexity

  Let N = number of expenses, R_e = expense rules, R_t = trip rules, T = trips.

  ┌────────────────────────┬────────────────────────────────────────────────────────────┐
  │       Operation        │                         Complexity                         │
  ├────────────────────────┼────────────────────────────────────────────────────────────┤
  │ Partition rules        │ O(R) once at construction                                  │
  ├────────────────────────┼────────────────────────────────────────────────────────────┤
  │ Per-expense evaluation │ O(N · R_e)                                                 │
  ├────────────────────────┼────────────────────────────────────────────────────────────┤
  │ Group by trip          │ O(N)                                                       │
  ├────────────────────────┼────────────────────────────────────────────────────────────┤
  │ Per-trip evaluation    │ O(N · R_t) total (each expense visited once per trip rule) │
  ├────────────────────────┼────────────────────────────────────────────────────────────┤
  │ Total                  │ O(N · (R_e + R_t))                                         │
  └────────────────────────┴────────────────────────────────────────────────────────────┘
  
  Space: O(N + V) where V is the number of violations.

  This is linear in expenses × rules — optimal, since each (expense, rule) pair must be checked at least once in the worst case.




  Employee Access Management System
  ==================================
  Standard library only: enum, collections.defaultdict.
  """

  from enum import Enum
  from collections import defaultdict


  class AccessType(Enum):
      """
      Access types as an enum for type safety.
      Adding a new tier (e.g., DELETE) means adding one line here.
      """
      READ = "READ"
      WRITE = "WRITE"
      ADMIN = "ADMIN"


  class AccessManager:
      """
      Manages employee -> resource -> access-type mappings.

      Storage: nested dict
          access_map[employee_id][resource_id] -> set[AccessType]

      All four operations are O(1) (or output-bounded for the retrievers).
      Empty containers are cleaned up so retrieve_resources never returns
      resources with no actual access.
      """

      def __init__(self):
          # defaultdict(lambda: defaultdict(set)) creates the nested
          # structure on demand without explicit None-checks.
          self._access_map = defaultdict(lambda: defaultdict(set))

      def grant_access(self, employee_id, resource_id, access_type):
          """Grant a specific access type. Idempotent. O(1)."""
          self._access_map[employee_id][resource_id].add(access_type)

      def revoke_access(self, employee_id, resource_id, access_type=None):
          """
          Revoke access. If access_type is None, revoke ALL access for this
          (employee, resource) pair. Silent no-op if nothing to revoke. O(1).

          Cleans up empty inner structures so retrieve_resources stays correct.
          """
          # Quick exit: employee has no grants at all.
          if employee_id not in self._access_map:
              return
          emp_resources = self._access_map[employee_id]

          # Quick exit: employee has no grants for this resource.
          if resource_id not in emp_resources:
              self._cleanup_employee(employee_id)
              return

          if access_type is None:
              # Revoke all access for this (employee, resource).
              del emp_resources[resource_id]
          else:
              emp_resources[resource_id].discard(access_type)
              # If the set is now empty, drop the resource entry.
              if not emp_resources[resource_id]:
                  del emp_resources[resource_id]

          self._cleanup_employee(employee_id)
  
      def retrieve_access(self, employee_id, resource_id):
          """
          Return all access types an employee has for a resource.
          Empty list if none. O(A) where A is the number of access types.
          """
          if employee_id not in self._access_map:
              return []
          if resource_id not in self._access_map[employee_id]:
              return []
          # Sort by enum-defined order for deterministic output.
          access_set = self._access_map[employee_id][resource_id]
          return sorted(access_set, key=lambda a: list(AccessType).index(a))

      def retrieve_resources(self, employee_id):
          """
          Return all resources an employee has any access to.
          O(R) where R is the number of resources for this employee.
          """
          if employee_id not in self._access_map:
              return []
          return list(self._access_map[employee_id].keys())

      # ---------- internal ----------

      def _cleanup_employee(self, employee_id):
          """If employee has no remaining grants, drop their entry."""
          if (employee_id in self._access_map
                  and not self._access_map[employee_id]):
              del self._access_map[employee_id]


  # ---------------------------------------------------------------------------
  # Demo
  # ---------------------------------------------------------------------------

  def demo():
      am = AccessManager()

      # Grant some access
      am.grant_access("E1", "R1", AccessType.READ)
      am.grant_access("E1", "R1", AccessType.WRITE)
      am.grant_access("E1", "R2", AccessType.READ)
      am.grant_access("E2", "R1", AccessType.ADMIN)

      # Idempotent grant -- granting same access twice is a no-op.
      am.grant_access("E1", "R1", AccessType.READ)

      print("E1 access to R1:", am.retrieve_access("E1", "R1"))
      # [READ, WRITE]
      print("E1 access to R2:", am.retrieve_access("E1", "R2"))  # [READ]
      print("E1 resources:", am.retrieve_resources("E1"))         # [R1, R2]
      print("E2 resources:", am.retrieve_resources("E2"))         # [R1]
      print("E3 resources:", am.retrieve_resources("E3"))         # []

      # Revoke specific access
      am.revoke_access("E1", "R1", AccessType.READ)
      print("After revoking READ from E1/R1:")
      print("  E1 access to R1:", am.retrieve_access("E1", "R1"))  # [WRITE]

      # Revoke all access -- should drop the resource from retrieve_resources
      am.revoke_access("E1", "R1", None)
      print("After revoking all from E1/R1:")
      print("  E1 access to R1:", am.retrieve_access("E1", "R1"))  # []
      print("  E1 resources:", am.retrieve_resources("E1"))         # [R2]

      # Revoke last remaining access -- E1 should disappear entirely
      am.revoke_access("E1", "R2", None)
      print("After revoking E1/R2:")
      print("  E1 resources:", am.retrieve_resources("E1"))         # []

      # Revoke non-existent access -- silent no-op
      am.revoke_access("E99", "R99", AccessType.READ)
      print("Revoking from non-existent employee: no error")


  if __name__ == "__main__":
      demo()

