  """
  Corporate Credit Card Rules Engine
  ===================================
  Design:
    - Rule (abstract base) -> ExpenseRule | TripRule
    - Engine evaluates ExpenseRules per expense, then groups by trip
      and evaluates TripRules per group.
    - Adding a new rule type = subclass Rule, no engine changes (OCP).

  Standard library only: decimal, collections.
  """

  from decimal import Decimal
  from collections import defaultdict


  # ---------------------------------------------------------------------------
  # Result type
  # ---------------------------------------------------------------------------

  class Violation:
      """Represents one rule failure. Carries enough context for the UI."""

      def __init__(self, rule_id, rule_description, expense_ids, trip_id=None):
          self.rule_id = rule_id
          self.rule_description = rule_description
          self.expense_ids = expense_ids   # list[str]
          self.trip_id = trip_id           # str | None for trip-level rules

      def __repr__(self):
          return (f"Violation(rule={self.rule_id}, "
                  f"expenses={self.expense_ids}, trip={self.trip_id}, "
                  f"desc='{self.rule_description}')")

  
  # ---------------------------------------------------------------------------
  # Rule hierarchy (Strategy pattern)
  # ---------------------------------------------------------------------------

  class Rule:
      """Abstract base for all rules."""

      def __init__(self, rule_id, description):
          self.rule_id = rule_id
          self.description = description


  class ExpenseRule(Rule):
      """
      A rule evaluated against a single expense in isolation.
      Subclasses implement check(expense) -> bool (True = violated).
      """

      def check(self, expense):
          raise NotImplementedError


  class TripRule(Rule):
      """
      A rule evaluated against all expenses belonging to one trip.
      Subclasses implement check(trip_expenses) -> list[str] of violating
      expense_ids (empty list = no violation).
      """

      def check(self, trip_expenses):
          raise NotImplementedError


  # ---------------------------------------------------------------------------
  # Concrete expense-level rules
  # ---------------------------------------------------------------------------

  class BanRule(ExpenseRule):
      """
      Ban any expense where a given field equals a banned value.
      Example: BanRule("R1", "expense_type", "airfare")
      """

      def __init__(self, rule_id, field, banned_value):
          super().__init__(rule_id, f"{field} cannot be '{banned_value}'")
          self.field = field
          self.banned_value = banned_value

      def check(self, expense):
          return expense.get(self.field) == self.banned_value


  class MaxAmountRule(ExpenseRule):
      """
      No single expense can exceed a max. Optionally scoped to a field/value
      (e.g., 'no restaurant expense > $75' = scope on vendor_type=restaurant).
      """

      def __init__(self, rule_id, max_amount, scope_field=None, scope_value=None):
          scope_desc = (f" at {scope_field}={scope_value}"
                        if scope_field else "")
          super().__init__(rule_id,
                           f"Single expense{scope_desc} cannot exceed "
                           f"${max_amount}")
          self.max_amount = Decimal(str(max_amount))
          self.scope_field = scope_field
          self.scope_value = scope_value

      def check(self, expense):
          # If scoped, only apply when the expense matches the scope.
          if self.scope_field is not None:
              if expense.get(self.scope_field) != self.scope_value:
                  return False
          amount = Decimal(expense["amount_usd"])
          return amount > self.max_amount


  # ---------------------------------------------------------------------------
  # Concrete trip-level rules
  # ---------------------------------------------------------------------------

  class TripTotalLimitRule(TripRule):
      """Total spend on a trip cannot exceed max_total."""

      def __init__(self, rule_id, max_total):
          super().__init__(rule_id, f"Trip total cannot exceed ${max_total}")
          self.max_total = Decimal(str(max_total))

      def check(self, trip_expenses):
          total = sum((Decimal(e["amount_usd"]) for e in trip_expenses),
                      Decimal("0"))
          if total > self.max_total:
              # Whole trip is in violation -> flag every expense.
              return [e["expense_id"] for e in trip_expenses]
          return []


  class FieldAggregationLimitRule(TripRule):
      """
      Generalized rule: sum of expenses where field == value, per trip,
      cannot exceed max_total. Powers both:
        - 'meal expenses cannot exceed $200/trip' (expense_type=meal)
        - 'expenses at restaurants cannot exceed $X/trip' (vendor_type=restaurant)
      """

      def __init__(self, rule_id, field, value, max_total):
          super().__init__(rule_id,
                           f"Total {field}={value} per trip cannot exceed "
                           f"${max_total}")
          self.field = field
          self.value = value
          self.max_total = Decimal(str(max_total))

      def check(self, trip_expenses):
          matching = [e for e in trip_expenses
                      if e.get(self.field) == self.value]
          total = sum((Decimal(e["amount_usd"]) for e in matching),
                      Decimal("0"))
          if total > self.max_total:
              return [e["expense_id"] for e in matching]
          return []


  # ---------------------------------------------------------------------------
  # Rules engine
  # ---------------------------------------------------------------------------

  class RulesEngine:
      """
      Evaluates a list of rules against a list of expenses.
      Splits rules by category once, then iterates expenses once for
      per-expense rules and one pass over trip groups for trip rules.
      """

      def __init__(self, rules):
          # Partition rules by category up front -> O(R) once, not per expense.
          self.expense_rules = [r for r in rules if isinstance(r, ExpenseRule)]
          self.trip_rules = [r for r in rules if isinstance(r, TripRule)]

      def evaluate(self, expenses):
          violations = []

          # 1. Per-expense rules: O(N * E) where E = number of expense rules.
          for expense in expenses:
              for rule in self.expense_rules:
                  if rule.check(expense):
                      violations.append(Violation(
                          rule_id=rule.rule_id,
                          rule_description=rule.description,
                          expense_ids=[expense["expense_id"]],
                          trip_id=expense.get("trip_id"),
                      ))

          # 2. Group expenses by trip_id once: O(N).
          trips = defaultdict(list)
          for expense in expenses:
              trips[expense["trip_id"]].append(expense)

          # 3. Per-trip rules: O(T * R_t * avg_trip_size).
          for trip_id, trip_expenses in trips.items():
              for rule in self.trip_rules:
                  offending_ids = rule.check(trip_expenses)
                  if offending_ids:
                      violations.append(Violation(
                          rule_id=rule.rule_id,
                          rule_description=rule.description,
                          expense_ids=offending_ids,
                          trip_id=trip_id,
                      ))

          return violations
  

  # ---------------------------------------------------------------------------
  # Function the interview asked for
  # ---------------------------------------------------------------------------

  def evaluate_rules(rules, expenses):
      return RulesEngine(rules).evaluate(expenses)


  # ---------------------------------------------------------------------------
  # Demo with the rules from the problem statement
  # ---------------------------------------------------------------------------

  def demo():
      rules = [
          # No restaurant expense > $75
          MaxAmountRule("R1", 75, scope_field="vendor_type",
                        scope_value="restaurant"),
          # No airfare expenses
          BanRule("R2", "expense_type", "airfare"),
          # No entertainment expenses
          BanRule("R3", "expense_type", "entertainment"),
          # No individual expense > $250
          MaxAmountRule("R4", 250),
          # Trip total cannot exceed $2000
          TripTotalLimitRule("R5", 2000),
          # Total meal expenses cannot exceed $200 per trip
          FieldAggregationLimitRule("R6", "expense_type", "meal", 200),
      ]

      expenses = [
          {"expense_id": "001", "trip_id": "T1", "amount_usd": "49.99",
           "expense_type": "client_hosting", "vendor_type": "restaurant",
           "vendor_name": "Outback"},
          {"expense_id": "002", "trip_id": "T1", "amount_usd": "120.00",
           "expense_type": "meal", "vendor_type": "restaurant",
           "vendor_name": "Chez Panisse"},  # Restaurant > $75 -> R1
          {"expense_id": "003", "trip_id": "T1", "amount_usd": "300.00",
           "expense_type": "airfare", "vendor_type": "airline",
           "vendor_name": "Delta"},  # Banned (R2) AND > $250 (R4)
          {"expense_id": "004", "trip_id": "T1", "amount_usd": "150.00",
           "expense_type": "meal", "vendor_type": "restaurant",
           "vendor_name": "Joe's"},  # Combined with #002 -> meal > $200 (R6)
      ]

      for v in evaluate_rules(rules, expenses):
          print(v)
  

  if __name__ == "__main__":
      demo()

