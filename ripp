# Food delivery 

from dataclasses import dataclass, field
  from datetime import datetime, timedelta
  from decimal import Decimal
  from heapq import heappush, heappop
  import itertools


  @dataclass(frozen=True)
  class Driver:
      id: int
      hourly_rate: Decimal


  @dataclass(frozen=True, order=False)
  class Delivery:
      driver_id: int
      start_time: datetime
      end_time: datetime
      cost: Decimal


  class DeliverySystem:
      def __init__(self) -> None:
          self._drivers: dict[int, Driver] = {}
          self._total_cost: Decimal = Decimal("0")
          self._total_unpaid: Decimal = Decimal("0")
          # Min-heap of (end_time, tie_breaker, Delivery)
          # tie_breaker avoids comparing Delivery objects on equal end_times
          self._unpaid: list[tuple[datetime, int, Delivery]] = []
          self._counter = itertools.count()

      def add_driver(self, driver_id: int, usd_hourly_rate: float) -> None:
          self._drivers[driver_id] = Driver(
              id=driver_id,
              hourly_rate=Decimal(str(usd_hourly_rate)),
          )

      def record_delivery(
          self, driver_id: int, start_time: datetime, end_time: datetime
      ) -> None:
          driver = self._drivers[driver_id]
          duration: timedelta = end_time - start_time
          hours = Decimal(str(duration.total_seconds())) / Decimal("3600")
          cost = driver.hourly_rate * hours

          delivery = Delivery(driver_id, start_time, end_time, cost)
          self._total_cost += cost
          self._total_unpaid += cost
          heappush(self._unpaid, (end_time, next(self._counter), delivery))

      def get_total_cost(self) -> Decimal:           # O(1)
          return self._total_cost

      # ---------- Q2 ----------
      def pay_up_to(self, pay_time: datetime) -> None:
          while self._unpaid and self._unpaid[0][0] <= pay_time:
              _, _, delivery = heappop(self._unpaid)
              self._total_unpaid -= delivery.cost

      def get_total_cost_unpaid(self) -> Decimal:    # O(1)
          return self._total_unpaid

  4. Quick Sanity Test

  from datetime import datetime, timezone

  sys = DeliverySystem()
  sys.add_driver(1, 10.00)

  t0 = datetime(2026, 5, 30, 9, 0, tzinfo=timezone.utc)
  t1 = t0 + timedelta(hours=1, minutes=30)   # 1.5h * $10 = $15.00
  sys.record_delivery(1, t0, t1)

  t2 = t1 + timedelta(hours=2)               # 2h * $10 = $20.00
  sys.record_delivery(1, t1, t2)

  print(sys.get_total_cost())          # 35.00
  print(sys.get_total_cost_unpaid())   # 35.00

  sys.pay_up_to(t1)                    # pays only the first delivery
  print(sys.get_total_cost_unpaid())   # 20.00
  print(sys.get_total_cost())          # 35.00 (unchanged — total is lifetime)
