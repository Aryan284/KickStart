  """
  Key-Value Store with Transactions
  ==================================
  Designed for nested transactions even though one level was asked first --
  the stack-of-dicts structure handles arbitrary depth with no extra code.

  Standard library only (no imports needed).
  """


  # Sentinel object for "this key was deleted in this transaction layer".
  # Using a unique singleton object so it can never collide with a user value.
  _DELETED = object()


  class KeyValueStore:
      """
      Layered key-value store:
        - committed: the base store, holds permanent values
        - tx_stack: list of dicts, one per active transaction layer
                    (top of stack is the innermost active transaction)

      Each layer maps key -> (value | _DELETED).
      Lookups walk top-down; the topmost layer wins.
      """

      def __init__(self):
          self._committed = {}    # str -> str
          self._tx_stack = []     # list[dict[str, str | _DELETED]]

      # -----------------------------------------------------------------------
      # Core operations
      # -----------------------------------------------------------------------

      def get(self, key):
          """
          Return value for key, or empty string if absent.
          Walks transaction stack top-down so reads see pending writes.
          """
          # Walk stack from top (most recent) to bottom (oldest).
          for layer in reversed(self._tx_stack):
              if key in layer:
                  value = layer[key]
                  # If deleted in this layer, it's gone -- don't fall through.
                  if value is _DELETED:
                      return ""
                  return value
          # Nothing in transactions; check the committed store.
          return self._committed.get(key, "")

      def set(self, key, value):
          """Set a key. Writes to the topmost transaction if active."""
          if self._tx_stack:
              self._tx_stack[-1][key] = value
          else:
              self._committed[key] = value

      def delete_key(self, key):
          """Delete a key. Records a sentinel in the topmost transaction."""
          if self._tx_stack:
              # Mark as deleted at this layer. Don't touch lower layers --
              # commit/rollback handles that.
              self._tx_stack[-1][key] = _DELETED
          else:
              self._committed.pop(key, None)

      # -----------------------------------------------------------------------
      # Transaction operations
      # -----------------------------------------------------------------------

      def begin(self):
          """Start a new transaction layer."""
          self._tx_stack.append({})

      def commit(self):
          """
          Apply the topmost transaction's changes to the layer below
          (or to the committed store if it was the only layer).
          """
          if not self._tx_stack:
              raise RuntimeError("commit called with no active transaction")

          top = self._tx_stack.pop()

          # Where do these changes go? Into the next layer down,
          # or into the committed store if no layer remains.
          target = self._tx_stack[-1] if self._tx_stack else self._committed

          for key, value in top.items():
              if value is _DELETED:
                  # Apply the deletion to the target.
                  if target is self._committed:
                      self._committed.pop(key, None)
                  else:
                      # Carry the deletion sentinel up to the parent layer
                      # so it's still visible there until parent commits.
                      target[key] = _DELETED
              else:
                  target[key] = value

      def rollback(self):
          """Discard the topmost transaction's changes."""
          if not self._tx_stack:
              raise RuntimeError("rollback called with no active transaction")
          self._tx_stack.pop()


  # ---------------------------------------------------------------------------
  # Demo
  # ---------------------------------------------------------------------------

  def demo():
      kv = KeyValueStore()

      # ----- Basic operations (no transaction) -----
      kv.set("a", "1")
      kv.set("b", "2")
      print("get('a'):", kv.get("a"))         # 1
      print("get('missing'):", kv.get("missing"))  # ''
      kv.delete_key("a")
      print("get('a') after delete:", kv.get("a"))  # ''

      # ----- Single transaction with commit -----
      kv.set("x", "10")
      kv.begin()
      kv.set("x", "20")
      kv.set("y", "30")
      print("\nInside tx:")
      print("  get('x'):", kv.get("x"))  # 20  (read-your-writes)
      print("  get('y'):", kv.get("y"))  # 30
      kv.commit()
      print("After commit:")
      print("  get('x'):", kv.get("x"))  # 20
      print("  get('y'):", kv.get("y"))  # 30

      # ----- Single transaction with rollback -----
      kv.begin()
      kv.set("x", "999")
      kv.delete_key("y")
      print("\nInside tx (uncommitted):")
      print("  get('x'):", kv.get("x"))  # 999
      print("  get('y'):", kv.get("y"))  # ''
      kv.rollback()
      print("After rollback:")
      print("  get('x'):", kv.get("x"))  # 20  (restored)
      print("  get('y'):", kv.get("y"))  # 30  (restored)

      # ----- Nested transactions (free, thanks to stack design) -----
      print("\n--- Nested transactions ---")
      kv.set("p", "100")
      kv.begin()                 # outer
      kv.set("p", "200")
      kv.begin()                 # inner
      kv.set("p", "300")
      print("Inside inner tx, get('p'):", kv.get("p"))  # 300
      kv.rollback()              # discard inner
      print("After inner rollback, get('p'):", kv.get("p"))  # 200
      kv.commit()                # commit outer
      print("After outer commit, get('p'):", kv.get("p"))    # 200

      # ----- Nested with deletion that bubbles up -----
      print("\n--- Nested deletion ---")
      kv.set("q", "alive")
      kv.begin()
      kv.delete_key("q")
      print("Inside tx, get('q'):", kv.get("q"))  # ''
      kv.begin()
      kv.set("q", "resurrected")
      print("Inside inner tx, get('q'):", kv.get("q"))  # resurrected
      kv.commit()  # inner -> outer (q='resurrected' now)
      print("After inner commit, get('q'):", kv.get("q"))  # resurrected
      kv.commit()  # outer -> committed
      print("After outer commit, get('q'):", kv.get("q"))  # resurrected


  if __name__ == "__main__":
      demo()
  
